@{
    var currentYear = DateTime.UtcNow.Year;

    // Recupera o Nonce gerado obrigatoriamente no Middleware do servidor (Startup.cs)
    var cspNonce = Context.Items["CspNonce"] as string;

    if (string.IsNullOrWhiteSpace(cspNonce))
    {
        // Princípio Fail-Fast: Impede a execução sem contexto de segurança válido
        throw new InvalidOperationException("CSP nonce ausente. Verifique o middleware responsável no Startup.cs.");
    }
}
<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="desenvolvimento de jogos e realidade virtual">
    <meta name="keywords" content="realidade virtual, criamos jogos, desenvolvemos jogos">
    
    <title>@ViewData["Title"] - Global Games | Welcome</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" nonce="@cspNonce" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/style.css" nonce="@cspNonce" asp-append-version="true" />
</head>

<body>
    <header>
        <div class="container">
            <div id="logo">
                <h1><span class="destaque">Global</span> Games Enterprise</h1>
            </div>
            <nav>
                <ul>
                    <li><a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="About">Sobre</a></li>
                    <li><a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Services">Serviços</a></li>                 
                </ul>
            </nav>
        </div>
    </header>

    <section id="showcase">
        <div class="container">
            <h1>A melhor plataforma de realidade virtual</h1>
            <p>Desenvolvemos experiências imersivas e jogos personalizados para empresas e usuários que buscam inovação em realidade virtual.</p>  
        </div>
    </section>
    
    <partial name="_Newsletter" />

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer>
        <p>Global Games, Copyright &copy; @currentYear</p>  
    </footer>

    @await RenderSectionAsync("Scripts", required: false)

    <script nonce="@cspNonce" src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script nonce="@cspNonce" src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>